# Database - PostgreSQL
POSTGRES_DB=smarttani
POSTGRES_USER=smarttani_user
POSTGRES_PASSWORD=smarttani_pass_staging_123

# Database - MongoDB
MONGO_ROOT_USER=smarttani_user
MONGO_ROOT_PASSWORD=smarttani_pass_staging_123
MONGO_DB=smarttani

# Redis
REDIS_PASSWORD=

# RabbitMQ
RABBITMQ_USER=smarttani
RABBITMQ_PASS=smarttani_pass_staging_123

# Security
JWT_SECRET=your_32_char_long_jwt_secret_for_staging
CORS_ORIGIN=https://staging.smarttani.id

# Midtrans (Sandbox)
MIDTRANS_SERVER_KEY=SB-Mid-server-xxxxxxxxxxxx
MIDTRANS_CLIENT_KEY=SB-Mid-client-xxxxxxxxxxxx

# AWS S3 (Images)
AWS_ACCESS_KEY_ID=xxxxxxxxxxxx
AWS_SECRET_ACCESS_KEY=xxxxxxxxxxxx
AWS_BUCKET_NAME=smarttani-staging
AWS_REGION=ap-southeast-1

# Firebase (Notifications)
FIREBASE_PROJECT_ID=smarttani-staging
FIREBASE_PRIVATE_KEY="-----BEGIN PRIVATE KEY-----\n...\n-----END PRIVATE KEY-----\n"
FIREBASE_CLIENT_EMAIL=firebase-adminsdk-xxxxx@smarttani-staging.iam.gserviceaccount.com
