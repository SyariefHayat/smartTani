# ==============================================================================
# SmartTani Platform - Global Environment Variables
# Copy this file to .env in the root or relevant service folders
# ==============================================================================

# --- App ---
NODE_ENV=development
PORT=3000
BASE_URL=http://localhost:3000

# --- Database ---
# PostgreSQL (Auth, Order, Investment, Analytics)
DATABASE_URL=postgresql://user:pass@localhost:5432/smarttani
# MongoDB (Marketplace, Logistics, Order)
MONGODB_URL=mongodb://user:pass@localhost:27017/smarttani
# Redis (Auth, Order, Analytics, Cart)
REDIS_URL=redis://localhost:6379

# --- RabbitMQ ---
# Used for async communication between services
RABBITMQ_URL=amqp://user:pass@localhost:5672

# --- Auth ---
# Secret for signing JWT tokens (min 32 chars recommended)
JWT_SECRET=your-secret-key-at-least-32-characters-long
JWT_EXPIRES_IN=1h
REFRESH_TOKEN_EXPIRES_IN=7d

# --- Storage (AWS S3 / MinIO) ---
# Used for product photos and document uploads
AWS_ACCESS_KEY_ID=your-access-key
AWS_SECRET_ACCESS_KEY=your-secret-key
AWS_BUCKET_NAME=smarttani-media
AWS_REGION=ap-southeast-1

# --- Payment (Midtrans) ---
# Used for transaction processing
MIDTRANS_SERVER_KEY=your-midtrans-server-key
MIDTRANS_CLIENT_KEY=your-midtrans-client-key
MIDTRANS_IS_PRODUCTION=false

# --- Email (SendGrid / Nodemailer) ---
# Used for sending verification and notification emails
SENDGRID_API_KEY=your-sendgrid-api-key
EMAIL_FROM=noreply@smarttani.id

# --- Firebase ---
# Used for FCM push notifications
FIREBASE_PROJECT_ID=your-firebase-id
FIREBASE_PRIVATE_KEY=your-firebase-private-key
FIREBASE_CLIENT_EMAIL=your-firebase-client-email

# --- Monitoring ---
# Error tracking and performance monitoring
SENTRY_DSN=your-sentry-dsn

# --- Platform Business Config ---
# Platform fee taken from every transaction (%)
PLATFORM_FEE_PERCENT=2
# Platform fee taken from every investment (%)
INVESTMENT_FEE_PERCENT=2.5
# Minimum investment amount in IDR
MIN_INVESTMENT_AMOUNT=100000
# Minutes before an unpaid order is automatically cancelled
ORDER_PAYMENT_TIMEOUT_MINUTES=15
# Days before a shipped order is automatically marked as completed
ORDER_AUTO_COMPLETE_DAYS=7
