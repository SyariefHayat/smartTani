generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

model User {
  id         String   @id @db.Uuid
  email      String   @unique @db.VarChar(255)
  role       String   @db.VarChar(50)
  status     String   @default("active") @db.VarChar(50)
  full_name  String?  @db.VarChar(255)
  created_at DateTime @default(now()) @db.Timestamptz
  updated_at DateTime @updatedAt @db.Timestamptz

  @@map("users")
}

model Order {
  id           String      @id @db.Uuid
  buyer_id     String      @db.Uuid
  total_amount Decimal     @db.Decimal(15, 2)
  status       String      @db.VarChar(50)
  created_at   DateTime    @default(now()) @db.Timestamptz
  updated_at   DateTime    @updatedAt @db.Timestamptz
  items        OrderItem[]

  @@map("orders")
}

model OrderItem {
  id             String  @id @db.Uuid
  order_id       String  @db.Uuid
  product_id     String  @db.Text
  farmer_id      String  @db.Uuid
  quantity       Decimal @db.Decimal(10, 2)
  price_per_unit Decimal @db.Decimal(15, 2)
  subtotal       Decimal @db.Decimal(15, 2)
  order          Order   @relation(fields: [order_id], references: [id])

  @@map("order_items")
}

model Proposal {
  id                    String       @id @db.Uuid
  farmer_id             String       @db.Uuid
  title                 String       @db.VarChar(255)
  commodity             String?      @db.VarChar(100)
  funding_needed        Decimal      @db.Decimal(15, 2)
  funding_raised        Decimal      @db.Decimal(15, 2)
  projected_roi_percent Decimal?     @db.Decimal(5, 2)
  status                String       @db.VarChar(50)
  created_at            DateTime     @default(now()) @db.Timestamptz
  updated_at            DateTime     @updatedAt @db.Timestamptz
  investments           Investment[]

  @@map("proposals")
}

model Investment {
  id               String   @id @db.Uuid
  investor_id      String   @db.Uuid
  proposal_id      String   @db.Uuid
  amount           Decimal  @db.Decimal(15, 2)
  projected_return Decimal? @db.Decimal(15, 2)
  actual_return    Decimal? @db.Decimal(15, 2)
  status           String   @db.VarChar(50)
  invested_at      DateTime @default(now()) @db.Timestamptz
  proposal         Proposal @relation(fields: [proposal_id], references: [id])

  @@map("investments")
}
